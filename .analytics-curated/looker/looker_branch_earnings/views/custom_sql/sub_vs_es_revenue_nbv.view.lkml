view: sub_vs_es_revenue_nbv {
  derived_table: {
    sql:
       SELECT 'SUBSIDIARY' AS COMPANY_TYPE,SCD.COMPANY_ID AS ASSET_COMPANY_ID, C.NAME AS ASSET_COMPANY_NAME, LI.ASSET_ID,
I.BILLING_APPROVED_DATE::DATE AS BILLING_APPROVED_DATE, SCD.DATE_START::DATE AS DATE_START, SCD.DATE_END::DATE AS DATE_END,
(SUM(LI.AMOUNT) - SUM(IFF(CNLI.CREDIT_AMOUNT IS NULL , 0, CNLI.CREDIT_AMOUNT))) AS REVENUE,
COALESCE(AA.OEC - LEAST(AA.OEC *
CASE WHEN AA.ASSET_TYPE IN ('vehicle','trailer') THEN .9 / (7 * 12) -- vehicle salvage = 10%, equip = 20%
ELSE .8 / (10 * 12) END *
GREATEST(0,
DATEDIFF(MONTH, IFF(AA.ASSET_TYPE = 'equipment',date_from_parts(year(AA.FIRST_RENTAL),month(AA.FIRST_RENTAL),15),
COALESCE(date_from_parts(year(AA.PURCHASE_DATE),month(AA.PURCHASE_DATE),15), date_from_parts(year(AA.DATE_CREATED),
month(AA.DATE_CREATED),15))),date_from_parts(year(I.BILLING_APPROVED_DATE::DATE),month(I.BILLING_APPROVED_DATE::DATE),15))
),
/*Salvage Value*/AA.OEC * CASE WHEN AA.ASSET_TYPE IN ('vehicle','trailer') THEN .9 ELSE .8 END) *
CASE WHEN AA.FIRST_RENTAL IS NULL AND AA.ASSET_TYPE = 'equipment' THEN 0 ELSE 1 END,AA.OEC) AS NBV,
(SELECT (SUM(LI.AMOUNT) - SUM(IFF(CNLI.CREDIT_AMOUNT IS NULL , 0, CNLI.CREDIT_AMOUNT)))
FROM ES_WAREHOUSE.PUBLIC.INVOICES AS I
LEFT JOIN ES_WAREHOUSE.PUBLIC.LINE_ITEMS AS LI ON I.INVOICE_ID = LI.INVOICE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.LINE_ITEM_TYPES AS LIT ON LI.LINE_ITEM_TYPE_ID = LIT.LINE_ITEM_TYPE_ID
LEFT JOIN ES_WAREHOUSE.SCD.SCD_ASSET_COMPANY AS SCD ON LI.ASSET_ID = SCD.ASSET_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANIES AS C ON SCD.COMPANY_ID = C.COMPANY_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.CREDIT_NOTES AS CN on I.INVOICE_ID = CN.ORIGINATING_INVOICE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.CREDIT_NOTE_LINE_ITEMS AS CNLI
ON CN.CREDIT_NOTE_ID = CNLI.CREDIT_NOTE_ID  AND CNLI.LINE_ITEM_ID = LI.LINE_ITEM_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.ASSETS_AGGREGATE AS AA ON LI.ASSET_ID = AA.ASSET_ID
WHERE (C.NAME regexp 'IES\\d+.*' OR
SCD.COMPANY_ID IN (62875,60101,3803,5334,1982,3667,66728,61702,46659,1181,
250,129,6860,4494,6954,57451,61127,73584,61204,61431,62606,38145,38562,8968,1855,5011,59110,57452,275,
57218,64440,60210,61567,5767,20832,14060,268,244,58452,6067,4544,2117,2132,2158,4490,
3582,164,39062,60540,1854,3789,60985,60981,53003,37918,4636,1819,2449,3671,299,420,61498,61551,61322,8334,1682,
5468,8231,61423,6470,25283,3080,2159,55524))
AND LI.LINE_ITEM_TYPE_ID IN (24,80,81,50,110,111)
AND I.BILLING_APPROVED_DATE::DATE BETWEEN {%  date_start date_filter %} and {% date_end date_filter %}
AND I.BILLING_APPROVED_DATE::DATE BETWEEN SCD.DATE_START::DATE AND SCD.DATE_END::DATE) AS TOTAL_REVENUE,
(SELECT SUM(COALESCE(AA.OEC - LEAST(AA.OEC *
CASE WHEN AA.ASSET_TYPE IN ('vehicle','trailer') THEN .9 / (7 * 12) -- vehicle salvage = 10%, equip = 20%
ELSE .8 / (10 * 12) END *
GREATEST(0,
DATEDIFF(MONTH, IFF(AA.ASSET_TYPE = 'equipment',date_from_parts(year(AA.FIRST_RENTAL),month(AA.FIRST_RENTAL),15),
COALESCE(date_from_parts(year(AA.PURCHASE_DATE),month(AA.PURCHASE_DATE),15), date_from_parts(year(AA.DATE_CREATED),
month(AA.DATE_CREATED),15))),date_from_parts(year(I.BILLING_APPROVED_DATE::DATE),month(I.BILLING_APPROVED_DATE::DATE),15))
),
/*Salvage Value*/AA.OEC * CASE WHEN AA.ASSET_TYPE IN ('vehicle','trailer') THEN .9 ELSE .8 END) *
CASE WHEN AA.FIRST_RENTAL IS NULL AND AA.ASSET_TYPE = 'equipment' THEN 0 ELSE 1 END,AA.OEC))
FROM ES_WAREHOUSE.PUBLIC.INVOICES AS I
LEFT JOIN ES_WAREHOUSE.PUBLIC.LINE_ITEMS AS LI ON I.INVOICE_ID = LI.INVOICE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.LINE_ITEM_TYPES AS LIT ON LI.LINE_ITEM_TYPE_ID = LIT.LINE_ITEM_TYPE_ID
LEFT JOIN ES_WAREHOUSE.SCD.SCD_ASSET_COMPANY AS SCD ON LI.ASSET_ID = SCD.ASSET_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANIES AS C ON SCD.COMPANY_ID = C.COMPANY_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.CREDIT_NOTES AS CN on I.INVOICE_ID = CN.ORIGINATING_INVOICE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.CREDIT_NOTE_LINE_ITEMS AS CNLI
ON CN.CREDIT_NOTE_ID = CNLI.CREDIT_NOTE_ID  AND CNLI.LINE_ITEM_ID = LI.LINE_ITEM_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.ASSETS_AGGREGATE AS AA ON LI.ASSET_ID = AA.ASSET_ID
WHERE (C.NAME regexp 'IES\\d+.*' OR
SCD.COMPANY_ID IN (62875,60101,3803,5334,1982,3667,66728,61702,46659,1181,
250,129,6860,4494,6954,57451,61127,73584,61204,61431,62606,38145,38562,8968,1855,5011,59110,57452,275,
57218,64440,60210,61567,5767,20832,14060,268,244,58452,6067,4544,2117,2132,2158,4490,
3582,164,39062,60540,1854,3789,60985,60981,53003,37918,4636,1819,2449,3671,299,420,61498,61551,61322,8334,1682,
5468,8231,61423,6470,25283,3080,2159,55524))
AND LI.LINE_ITEM_TYPE_ID IN (24,80,81,50,110,111)
AND I.BILLING_APPROVED_DATE::DATE BETWEEN {%  date_start date_filter %} and {% date_end date_filter %}
AND I.BILLING_APPROVED_DATE::DATE BETWEEN SCD.DATE_START::DATE AND SCD.DATE_END::DATE) AS TOTAL_NBV
FROM ES_WAREHOUSE.PUBLIC.INVOICES AS I
LEFT JOIN ES_WAREHOUSE.PUBLIC.LINE_ITEMS AS LI ON I.INVOICE_ID = LI.INVOICE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.LINE_ITEM_TYPES AS LIT ON LI.LINE_ITEM_TYPE_ID = LIT.LINE_ITEM_TYPE_ID
LEFT JOIN ES_WAREHOUSE.SCD.SCD_ASSET_COMPANY AS SCD ON LI.ASSET_ID = SCD.ASSET_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANIES AS C ON SCD.COMPANY_ID = C.COMPANY_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.CREDIT_NOTES AS CN on I.INVOICE_ID = CN.ORIGINATING_INVOICE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.CREDIT_NOTE_LINE_ITEMS AS CNLI
ON CN.CREDIT_NOTE_ID = CNLI.CREDIT_NOTE_ID  AND CNLI.LINE_ITEM_ID = LI.LINE_ITEM_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.ASSETS_AGGREGATE AS AA ON LI.ASSET_ID = AA.ASSET_ID
WHERE C.NAME regexp 'IES\\d+.*'
AND LI.LINE_ITEM_TYPE_ID IN (24,80,81,50,110,111)
AND I.BILLING_APPROVED_DATE::DATE BETWEEN {%  date_start date_filter %} and {% date_end date_filter %}
AND I.BILLING_APPROVED_DATE::DATE BETWEEN SCD.DATE_START::DATE AND SCD.DATE_END::DATE
GROUP BY SCD.COMPANY_ID, C.NAME, LI.ASSET_ID, I.BILLING_APPROVED_DATE, SCD.DATE_START, SCD.DATE_END,
AA.OEC, AA.ASSET_TYPE, AA.FIRST_RENTAL, AA.PURCHASE_DATE,AA.DATE_CREATED
HAVING REVENUE > 0      ;;
  }

 filter: date_filter {
    type: date
  }



  dimension: company_type {
    type: string
    sql: ${TABLE}."COMPANY_TYPE" ;;
  }

  dimension: asset_company_id {
    type: string
    sql: ${TABLE}."ASSET_COMPANY_ID" ;;
  }

  dimension: asset_company_name {
    type: string
    sql: ${TABLE}."ASSET_COMPANY_NAME" ;;
  }

  dimension: asset_id {
    type: string
    sql: ${TABLE}."ASSET_ID" ;;
  }

  dimension: billing_approved_date {
    type: date
    sql: ${TABLE}."BILLING_APPROVED_DATE" ;;
  }

  dimension: date_start {
    type: date
    sql: ${TABLE}."DATE_START" ;;
  }

  dimension: date_end {
    type: date
    sql: ${TABLE}."DATE_END" ;;
  }



  measure: revenue {
    type: sum
    sql:  ${TABLE}."REVENUE"  ;;
  }

  measure: total_revenue {
    type: average
    sql:  ${TABLE}."TOTAL_REVENUE"  ;;
  }

  measure: total_nbv {
    type: average
    sql:  ${TABLE}."TOTAL_NBV"  ;;
  }



  measure: nbv {
    type: sum
    sql:${TABLE}."NBV"  ;;
  }

  }
