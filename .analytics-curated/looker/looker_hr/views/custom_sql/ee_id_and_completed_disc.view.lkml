view: ee_id_and_completed_disc {
  derived_table: {
    sql:
    WITH disc_complete as(
    SELECT *
    FROM ANALYTICS.PUBLIC.DISC_MASTER
    WHERE COMPLETED_DATE is not null
)
SELECT EMPLOYEE_ID, coalesce(dm2.DISC_CODE,dm1.DISC_CODE) as DISC_CODE
FROM ANALYTICS.PAYROLL.COMPANY_DIRECTORY cd
LEFT JOIN disc_complete dm1 on lower(cd.PERSONAL_EMAIL) = lower(dm1.EMAIL_ADDRESS)
left join disc_complete dm2 on lower(cd.WORK_EMAIL) = lower(dm2.EMAIL_ADDRESS);;
  }
dimension: employee_id {
  type: number
  sql: ${TABLE}.EMPLOYEE_ID ;;
}

dimension: disc_code {
  type: string
  sql: ${TABLE}.DISC_CODE ;;
}
