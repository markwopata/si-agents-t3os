view: telematics_branch_trend {

  derived_table: {
    sql:
   SELECT RS.ASSET_ID AS ASSET_ID, RS.RENTAL_STATUS AS RENTAL_STATUS, RS.DATE_START::DATE AS DATE_START, RS.DATE_END::DATE AS DATE_END,
RB.RENTAL_BRANCH_ID AS RENTAL_BRANCH_ID, M.NAME AS BRANCH,
COALESCE(A.SERIAL_NUMBER,A.VIN) AS SERIAL_VIN, A.YEAR AS YEAR, A.MAKE AS MAKE, A.MODEL AS MODEL, A.TRACKER_ID AS TRACKER_ID
FROM ES_WAREHOUSE.SCD.SCD_ASSET_RENTAL_STATUS AS RS
LEFT JOIN ES_WAREHOUSE.SCD.ASSET_SCD_RENTAL_BRANCH AS RB
ON RS.ASSET_ID = RB.ASSET_ID AND RS.DATE_START::DATE BETWEEN RB.DATE_START AND RB.DATE_END::DATE
AND RS.DATE_END::DATE BETWEEN RB.DATE_START::DATE AND RB.DATE_END::DATE
LEFT JOIN ES_WAREHOUSE.PUBLIC.MARKETS AS M
ON RB.RENTAL_BRANCH_ID = M.MARKET_ID
LEFT JOIN ES_WAREHOUSE.SCD.SCD_ASSET_COMPANY AS AC
ON RS.ASSET_ID = AC.ASSET_ID AND RS.DATE_START::DATE BETWEEN AC.DATE_START::DATE AND AC.DATE_END::DATE
AND RS.DATE_END::DATE BETWEEN AC.DATE_START AND AC.DATE_END::DATE
LEFT JOIN ES_WAREHOUSE.PUBLIC.ASSETS AS A
ON RS.ASSET_ID = A.ASSET_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.ASSETS_AGGREGATE AS AA
ON RS.ASSET_ID = AA.ASSET_ID
left join ES_WAREHOUSE."PUBLIC".asset_tracker_assignments ata
on RS.asset_id=ata.asset_id
WHERE lower(RS.RENTAL_STATUS) = 'on rent'
AND BRANCH IS NOT NULL
AND AC.COMPANY_ID = 1854
AND A.TRACKER_ID IS NULL  AND ATA.TRACKER_ID IS NULL AND SUBSTR(TRIM(A.SERIAL_NUMBER), 1, 3) != 'RR-'
and AA.category not in ('Attachments','AG Tractors','Agriculture & Landscaping','Cutting & Coring','Electrical Equipment','Fans',
'Fans & Dehumidifiers','Forklift Attachments','Forklift and Telehandler Attachments','Fuel Storage','Heaters','Masonry & Tile Saws','Mixers','Power Tools','Power Tools & Small Equipment',
