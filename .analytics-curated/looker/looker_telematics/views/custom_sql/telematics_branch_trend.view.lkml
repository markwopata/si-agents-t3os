  dimension: asset_id {
    type: number
    sql: ${TABLE}.ASSET_ID ;;
  }

  dimension:rental_status {
    type: string
    sql: ${TABLE}.RENTAL_STATUS ;;
  }

  dimension: date_start {
    type: date
    sql: ${TABLE}.DATE_START ;;
  }

  dimension: date_end {
    type: date
    sql: ${TABLE}.DATE_END ;;
  }

  dimension: rental_branch_id {
    type: number
    sql: ${TABLE}.RENTAL_BRANCH_ID ;;
  }

  dimension: branch {
    type: string
    sql: ${TABLE}.BRANCH ;;
  }

  dimension: serial_vin {
    type: string
    sql: ${TABLE}.SERIAL_VIN ;;
  }

  dimension: year {
    type: string
    sql: ${TABLE}.YEAR ;;
  }

  dimension: make {
    type: string
    sql: ${TABLE}.MAKE ;;
  }

  dimension: model {
    type: string
    sql: ${TABLE}.MODEL ;;
  }

  dimension: tracker_id {
    type: number
    sql: ${TABLE}.TRACKER_ID ;;
  }



  set: trend_details {
    fields: [asset_id,serial_vin,rental_status,rental_branch_id,branch,date_start,date_end,year,make,model,tracker_id]
  }

  measure: 1_to_3_weeks {
    type: count_distinct
    drill_fields: [trend_details*]
    sql: case when datediff(day,current_date,${date_start}) between 7 and 21 then ${asset_id} else 0 end ;;
  }

  measure: 1_to_3_months {
    type: count_distinct
    drill_fields: [trend_details*]
    sql: case when datediff(day,current_date,${date_start}) between 30 and 90 then ${asset_id} else 0 end ;;
  }


  measure: 1_year {
    type: count_distinct
    drill_fields: [trend_details*]
    sql: case when year(${date_start}) = year(current_date)-1   then ${asset_id} else 0 end ;;
  }

