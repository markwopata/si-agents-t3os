AND LEFT(T.DEVICE_SERIAL,3) <> '453'
AND T.DEVICE_SERIAL IS NOT NULL
AND LEFT(T.DEVICE_SERIAL,1) <> '-'
AND T.DEVICE_SERIAL <> ''
AND T.TRACKER_ID IS NOT NULL
AND (A.COMPANY_ID <> 155 OR A.COMPANY_ID IS NULL)
AND left(t.DEVICE_SERIAL,2) <> '35'
)
                           ;;
  }

  dimension: tracker_serial {
    type: string
    sql: ${TABLE}.TRACKER_SERIAL ;;
  }

  dimension: tracker_id {
    type: number
    sql: ${TABLE}.TRACKER_ID ;;
  }

  dimension: asset_id {
    type: string
    sql: ${TABLE}.ASSET_ID ;;
  }

  dimension: owner_company_id {
    type: number
    sql: ${TABLE}.OWNER_COMPANY_ID ;;
  }

  dimension: owner_company_name {
    type: string
    sql: ${TABLE}.OWNER_COMPANY_NAME ;;
  }

  dimension: make {
    type: string
    sql: ${TABLE}.MAKE ;;
  }

  dimension: model {
    type: string
    sql: ${TABLE}.MODEL ;;
  }

  dimension: category {
    type: string
    sql: ${TABLE}.CATEGORY ;;
  }

  dimension: tracker_type {
    type: string
    sql: ${TABLE}.TRACKER_TYPE ;;
  }

  dimension: tracker_firmware_version {
    type: string
    sql: ${TABLE}.TRACKER_FIRMWARE_VERSION ;;
  }

  dimension: modem_firmware_version {
    type: string
    sql: ${TABLE}.MODEM_FIRMWARE_VERSION ;;
  }

  dimension: inventory_branch_id {
    type: number
    sql: ${TABLE}.INVENTORY_BRANCH_ID ;;
  }

  dimension: inventory_branch {
    type: string
    sql: ${TABLE}.INVENTORY_BRANCH ;;
  }

  dimension: ool_timestamp {
    type: date_time
    sql: ${TABLE}.OOL_TIMESTAMP ;;
  }

  dimension: unplugged {
    type: string
    sql: ${TABLE}.UNPLUGGED ;;
  }

  dimension: latitude {
    type: string
    sql: ${TABLE}.LATITUDE ;;
  }

  dimension: longitude {
    type: string
    sql: ${TABLE}.LONGITUDE ;;
  }

  dimension: gps_coordinates {
    type:  location
    sql_latitude: ${latitude} ;;
    sql_longitude: ${longitude} ;;
  }

  dimension: latest_gps_fix_timestamp {
    type: date_time
    sql: ${TABLE}.LATEST_GPS_FIX_TIMESTAMP ;;
  }

  dimension: rental_status {
    type: string
    sql: ${TABLE}.RENTAL_STATUS ;;
  }

  dimension: last_checkin_timestamp {
    type: string
    sql: ${TABLE}.LAST_CHECKIN_TIMESTAMP ;;
  }

  dimension: asset_battery {
    type: string
    sql: ${TABLE}.BATTERY_VOLTAGE ;;
  }

  dimension: iccid {
    type: string
    sql: ${TABLE}.ICCID ;;
  }

  dimension: own_program {
    type: string
    sql: ${TABLE}.OWN_PROGRAM ;;
  }

  dimension: location {
    type: string
    sql: ${TABLE}.LOCATION ;;
  }

  dimension: risk_level {
    type: string
    sql: ${TABLE}.RISK_LEVEL ;;
  }

  dimension: rssi {
    type: string
    sql: ${TABLE}.RSSI ;;
  }

  dimension: update_status {
    type: string
    sql: ${TABLE}.UPDATE_STATUS ;;
  }

  dimension: part_info {
    type: string
    sql: ${TABLE}.PART_INFO ;;
  }

  dimension: owner_group {
    type: string
    sql: ${TABLE}.OWNER_GROUP  ;;
  }

  dimension: tracker_state {
    type: string
    sql: ${TABLE}.TRACKER_STATE ;;
  }

  dimension: customer_id {
    type: number
    sql: ${TABLE}.CUSTOMER_ID ;;
  }

  dimension: keypad_id {
    type: string
    sql: ${TABLE}.KEYPAD_ID ;;
  }

  dimension: keypad_serial {
    type: string
    sql: ${TABLE}.KEYPAD_SERIAL ;;
  }

  dimension: customer_name {
    type: string
    sql:CASE WHEN ${TABLE}.CUSTOMER_NAME IS NULL THEN 'NOT ON RENT' ELSE ${TABLE}.CUSTOMER_NAME END  ;;
  }

  dimension: completed_update_timestamp {
    type: date_time
    sql: ${TABLE}.COMPLETED_UPDATE_TIMESTAMP ;;
  }

  dimension: morey_firmware_update_request_status {
    type: string
    sql: ${TABLE}.MOREY_FIRMWARE_UPDATE_REQUEST_STATUS ;;
  }

  dimension: apn_value {
    type: string
    sql: ${TABLE}.APN_VALUE ;;
  }

  measure: update_completed_count {
    type: sum
    sql: case when ${update_status} = 'Completed' then 1 else 0 end  ;;
  }

  measure: update_not_completed {
    type: sum
    sql: case when ${update_status} = 'Not Completed' then 1 else 0 end  ;;
  }

  }
