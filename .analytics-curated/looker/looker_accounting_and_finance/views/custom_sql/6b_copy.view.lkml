               AND ${TABLE}.INSTALLED_DATE < ${TABLE}.UNINSTALLED_DATE THEN 1
          ELSE 0
       END ;;
    }

    dimension: LIVE_ASSET {
      type: number
      sql: CASE
          WHEN ${TABLE}.FIRST_INSTALL_DATE IS NOT NULL
               AND ${TABLE}.INSTALLED_DATE > ${TABLE}.UNINSTALLED_DATE THEN 1
          ELSE 0
       END ;;
    }

    dimension: REASSIGNMENTS {
      type: number
      sql: CASE
          WHEN ${TABLE}.UNINSTALLED_DATE IS NULL
               OR (${TABLE}.INSTALLED_DATE > ${TABLE}.UNINSTALLED_DATE
                   AND ${TABLE}.FIRST_INSTALL_DATE IS NOT NULL) THEN 1
          ELSE 0
       END ;;
    }

    dimension: UNUSED_TRACKER {
      type: string
      sql: CASE
          WHEN ${TABLE}.SHIPPED_DATE IS NOT NULL
               AND ${TABLE}.FIRST_INSTALL_DATE IS NULL THEN 'UNUSED TRACKER'
          WHEN ${TABLE}.SHIPPED_DATE IS NULL THEN 'NOT SHIPPED'
          ELSE 'INITIALLY INSTALLED'
       END ;;
    }
