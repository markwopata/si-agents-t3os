view: clio_newly_imported_matters {
  derived_table: {
    sql:
SELECT
SMA.MATTER,
SMA.STATUS,
SMA._ES_UPDATE_TIMESTAMP,
CAST(SMA._ES_UPDATE_TIMESTAMP AS DATE) AS UPDATE_DATE
FROM ANALYTICS.CLIO.SYNCED_MATTERS_ALT SMA
WHERE SMA._ES_UPDATE_TIMESTAMP IS NOT NULL
ORDER BY SMA._ES_UPDATE_TIMESTAMP DESC
    ;;
  }


  dimension: MATTER {
    type: string
    sql: ${TABLE}.MATTER;;
  }

  dimension: STATUS {
    type: string
    sql: ${TABLE}.STATUS;;
  }

  dimension: UPLOAD_TIMESTAMP {
    type: date_time
    sql: ${TABLE}._ES_UPDATE_TIMESTAMP;;
  }

  dimension: UPLOAD_DATE {
    type: date
    sql: ${TABLE}.UPDATE_DATE;;
  }



