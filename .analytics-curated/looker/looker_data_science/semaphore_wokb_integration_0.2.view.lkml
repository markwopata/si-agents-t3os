  #   description: "Use this for counting lifetime orders across many users"
  #   type: sum
  #   sql: ${lifetime_orders} ;;
  # }
}

  dimension: asset_id {}
  dimension: days_spread {}
  dimension: work_order_date_created {}
  dimension: note {}
#  dimension: date_of_semaphore {}
#  dimension: cause {}
#  dimension: complaint {}
#  dimension: correction {}
  dimension: dtc_code_list {}

}
