view: vendor_reimbursements {
  derived_table: {
    sql:
-- INVOICE QUERY
WITH EXCLUDE_CTE AS (
SELECT DISTINCT SERIAL
FROM ANALYTICS.REIMBURSEMENTS.EXCLUDED_SERIALS
WHERE SERIAL IS NOT NULL
)
-- ALL MODELS
SELECT PO.VENDOR_ID,
C1.NAME AS VENDOR_NAME,
CONCAT(CPT.prefix,'PO',POL.COMPANY_PURCHASE_ORDER_ID) AS ORDER_NUMBER_GROUPED,
CONCAT(CPT.prefix,'PO',POL.COMPANY_PURCHASE_ORDER_ID,'-',POL.COMPANY_PURCHASE_ORDER_LINE_ITEM_NUMBER) AS ORDER_NUMBER,
POL.INVOICE_NUMBER,
POL.INVOICE_DATE,
POL.RELEASE_DATE,
POL.ASSET_ID,
COALESCE(POL.SERIAL,POL.VIN) AS SERIAL_VIN,
POL.ORDER_STATUS,
POL.FINANCE_STATUS,
EMA.NAME AS EQUIPMENT_MAKE,
EMO.NAME AS EQUIPMENT_MODEL,
POL.YEAR AS MODEL_YEAR,
POL.FACTORY_BUILD_SPECIFICATIONS,
AA.COMPANY_ID AS OWNER_ID,
C2.NAME AS OWNER_NAME,
POL.NET_PRICE,
POL.FREIGHT_COST,
POL.SALES_TAX,
COALESCE(POL.NET_PRICE,0) + COALESCE(POL.FREIGHT_COST,0) + COALESCE(POL.SALES_TAX,0) + COALESCE(POL.AFTERMARKET_OEC,0) - COALESCE(POL.REBATE,0) AS TOTAL_OEC,
COALESCE(POL.NET_PRICE,0) + COALESCE(POL.FREIGHT_COST,0) + COALESCE(POL.AFTERMARKET_OEC,0) - COALESCE(POL.REBATE,0) AS OEC_LESS_TAX,
PO.APPROVED_AT AS PO_APPROVED_DATE,
POL.NOTE,
V.RULE_ID,
V.RULE_YEAR,
R.RULE,
R.REIMBURSEMENT_RATE,
CASE
WHEN (V.RULE_ID = 1) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') OR POL.FINANCE_STATUS IS NULL) THEN POL.NET_PRICE-(POL.NET_PRICE/1.05)
WHEN (V.RULE_ID = 13) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') AND (ORDER_NUMBER_GROUPED <> 'BPO122241') OR POL.FINANCE_STATUS IS NULL) THEN POL.NET_PRICE-(POL.NET_PRICE/1.05)
WHEN (V.RULE_ID IN (2,3,4,5)) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') OR POL.FINANCE_STATUS IS NULL) THEN R.REIMBURSEMENT_RATE * POL.NET_PRICE
WHEN (V.RULE_ID = 14) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') AND (ORDER_NUMBER_GROUPED NOT IN ('SPO124008','SPO124009','SPO124010','SPO124011','SPO124012')) OR POL.FINANCE_STATUS IS NULL) THEN R.REIMBURSEMENT_RATE * POL.NET_PRICE
WHEN (V.RULE_ID = 22) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') AND (ORDER_NUMBER_GROUPED NOT IN ('SPO124454')) OR POL.FINANCE_STATUS IS NULL) THEN R.REIMBURSEMENT_RATE * POL.NET_PRICE
WHEN (V.RULE_ID = 23) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') AND (ORDER_NUMBER_GROUPED NOT IN ('SPO122563','SPO124540','SPO124687')) OR POL.FINANCE_STATUS IS NULL) THEN R.REIMBURSEMENT_RATE * POL.NET_PRICE
WHEN (V.RULE_ID IN (6,7)) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') OR POL.FINANCE_STATUS IS NULL) THEN R.REIMBURSEMENT_RATE * TOTAL_OEC
WHEN (V.RULE_ID IN (8,9,29)) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') OR POL.FINANCE_STATUS IS NULL) THEN R.REIMBURSEMENT_RATE * OEC_LESS_TAX
ELSE 0.00 END AS REIMBURSEMENT_AMOUNT
FROM ES_WAREHOUSE.PUBLIC.COMPANY_PURCHASE_ORDER_LINE_ITEMS AS POL
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANY_PURCHASE_ORDERS AS PO ON POL.COMPANY_PURCHASE_ORDER_ID = PO.COMPANY_PURCHASE_ORDER_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANY_PURCHASE_ORDER_TYPES AS CPT ON PO.COMPANY_PURCHASE_ORDER_TYPE_ID = CPT.COMPANY_PURCHASE_ORDER_TYPE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANIES AS C1 ON PO.VENDOR_ID = C1.COMPANY_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.ASSETS_AGGREGATE AS AA ON POL.ASSET_ID = AA.ASSET_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.EQUIPMENT_MODELS AS EMO ON POL.EQUIPMENT_MODEL_ID = EMO.EQUIPMENT_MODEL_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.EQUIPMENT_MAKES AS EMA ON EMO.EQUIPMENT_MAKE_ID = EMA.EQUIPMENT_MAKE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANIES AS C2 ON AA.COMPANY_ID = C2.COMPANY_ID
INNER JOIN ANALYTICS.REIMBURSEMENTS.VENDOR_RULES AS V ON (PO.VENDOR_ID = V.VENDOR_ID) AND (V.RULE_YEAR = YEAR(POL.INVOICE_DATE))
LEFT JOIN ANALYTICS.REIMBURSEMENTS.VENDOR_RULES_RATES AS R ON V.RULE_ID = R.RULE_ID
WHERE C1.SUPPLY_VENDOR = TRUE
AND POL.DELETED_AT IS NULL
AND POL.INVOICE_DATE >= '2026-01-01' AND POL.INVOICE_DATE < '2026-04-01'
AND (COALESCE(POL.SERIAL, POL.VIN) NOT IN (SELECT DISTINCT SERIAL FROM EXCLUDE_CTE) OR COALESCE(POL.SERIAL, POL.VIN) IS NULL)
AND ORDER_NUMBER NOT IN ('SPO119483-2','SPO123276-2','SPO135767-1')
AND ORDER_NUMBER_GROUPED NOT IN ('BPO122241',
'SPO135927',
'SPO135928',
'SPO135929',
'SPO135930',
'SPO135931',
'SPO135932',
'SPO135933',
'SPO135934',
'SPO135935',
'SPO135936',
'SPO135944',
'SPO135937',
'SPO135945',
'SPO135938',
'SPO135939',
'SPO135940',
'SPO135941',
'SPO135946',
'SPO135947',
'SPO135948',
'SPO135949',
'SPO135942',
'SPO135943'
)
AND ((POL.NOTE NOT LIKE '%CPE%' AND POL.NOTE NOT LIKE '%IES%' AND POL.NOTE NOT LIKE '%VLP%') OR POL.NOTE IS NULL)
AND V.BASIS_TYPE <> 'Model Specific'
UNION ALL
-- MODEL SPECIFIC - MODEL
SELECT PO.VENDOR_ID,
C1.NAME AS VENDOR_NAME,
CONCAT(CPT.prefix,'PO',POL.COMPANY_PURCHASE_ORDER_ID) AS ORDER_NUMBER_GROUPED,
CONCAT(CPT.prefix,'PO',POL.COMPANY_PURCHASE_ORDER_ID,'-',POL.COMPANY_PURCHASE_ORDER_LINE_ITEM_NUMBER) AS ORDER_NUMBER,
POL.INVOICE_NUMBER,
POL.INVOICE_DATE,
POL.RELEASE_DATE,
POL.ASSET_ID,
COALESCE(POL.SERIAL,POL.VIN) AS SERIAL_VIN,
POL.ORDER_STATUS,
POL.FINANCE_STATUS,
EMA.NAME AS EQUIPMENT_MAKE,
EMO.NAME AS EQUIPMENT_MODEL,
POL.YEAR AS MODEL_YEAR,
POL.FACTORY_BUILD_SPECIFICATIONS,
AA.COMPANY_ID AS OWNER_ID,
C2.NAME AS OWNER_NAME,
POL.NET_PRICE,
POL.FREIGHT_COST,
POL.SALES_TAX,
COALESCE(POL.NET_PRICE,0) + COALESCE(POL.FREIGHT_COST,0) + COALESCE(POL.SALES_TAX,0) + COALESCE(POL.AFTERMARKET_OEC,0) - COALESCE(POL.REBATE,0) AS TOTAL_OEC,
COALESCE(POL.NET_PRICE,0) + COALESCE(POL.FREIGHT_COST,0) + COALESCE(POL.AFTERMARKET_OEC,0) - COALESCE(POL.REBATE,0) AS OEC_LESS_TAX,
PO.APPROVED_AT AS PO_APPROVED_DATE,
POL.NOTE,
V.RULE_ID,
V.RULE_YEAR,
R.RULE,
R.REIMBURSEMENT_RATE,
CASE WHEN POL.FINANCE_STATUS IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms')  THEN 0.00
WHEN (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') OR POL.FINANCE_STATUS IS NULL) THEN IFNULL(MS.REBATE_AMOUNT,0)  ELSE 0.00 END AS REIMBURSEMENT_AMOUNT
FROM ES_WAREHOUSE.PUBLIC.COMPANY_PURCHASE_ORDER_LINE_ITEMS AS POL
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANY_PURCHASE_ORDERS AS PO ON POL.COMPANY_PURCHASE_ORDER_ID = PO.COMPANY_PURCHASE_ORDER_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANY_PURCHASE_ORDER_TYPES AS CPT ON PO.COMPANY_PURCHASE_ORDER_TYPE_ID = CPT.COMPANY_PURCHASE_ORDER_TYPE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANIES AS C1 ON PO.VENDOR_ID = C1.COMPANY_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.ASSETS_AGGREGATE AS AA ON POL.ASSET_ID = AA.ASSET_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.EQUIPMENT_MODELS AS EMO ON POL.EQUIPMENT_MODEL_ID = EMO.EQUIPMENT_MODEL_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.EQUIPMENT_MAKES AS EMA ON EMO.EQUIPMENT_MAKE_ID = EMA.EQUIPMENT_MAKE_ID
LEFT JOIN ES_WAREHOUSE.PUBLIC.COMPANIES AS C2 ON AA.COMPANY_ID = C2.COMPANY_ID
LEFT JOIN ANALYTICS.REIMBURSEMENTS.VENDOR_RULES AS V ON (PO.VENDOR_ID = V.VENDOR_ID) AND (V.RULE_YEAR = YEAR(POL.INVOICE_DATE))
LEFT JOIN ANALYTICS.REIMBURSEMENTS.MANUFACTURE_SPECIFIC AS MS ON (LOWER(EMA.NAME) = LOWER(MS.MAKE)) AND (LOWER(EMO.NAME) = LOWER(MS.MODEL))
LEFT JOIN ANALYTICS.REIMBURSEMENTS.VENDOR_RULES_RATES AS R ON MS.RULE_ID = R.RULE_ID
WHERE C1.SUPPLY_VENDOR = TRUE
AND (EMO.NAME NOT ILIKE '%bucket%' OR EMO.NAME IS NULL)
AND POL.DELETED_AT IS NULL
AND POL.INVOICE_DATE >= '2026-01-01' AND POL.INVOICE_DATE < '2026-04-01'
AND POL.INVOICE_DATE::DATE >= MS.EFFECTIVE_DATE::DATE
AND (COALESCE(POL.SERIAL, POL.VIN) NOT IN (SELECT DISTINCT SERIAL FROM EXCLUDE_CTE) OR COALESCE(POL.SERIAL, POL.VIN) IS NULL)
AND MS.RULE_ID = 12
AND MS.TYPE = 'Model'
AND ((POL.NOTE NOT LIKE '%CPE%' AND POL.NOTE NOT LIKE '%IES%' AND POL.NOTE NOT LIKE '%VLP%') OR POL.NOTE IS NULL)
UNION ALL
-- MODEL SPECIFIC - FACTORY BUILD SPEC
SELECT PO.VENDOR_ID,
C1.NAME AS VENDOR_NAME,
CONCAT(CPT.prefix,'PO',POL.COMPANY_PURCHASE_ORDER_ID) AS ORDER_NUMBER_GROUPED,
CONCAT(CPT.prefix,'PO',POL.COMPANY_PURCHASE_ORDER_ID,'-',POL.COMPANY_PURCHASE_ORDER_LINE_ITEM_NUMBER) AS ORDER_NUMBER,
