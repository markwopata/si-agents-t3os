COALESCE(POL.NET_PRICE,0) + COALESCE(POL.FREIGHT_COST,0) + COALESCE(POL.AFTERMARKET_OEC,0) - COALESCE(POL.REBATE,0) AS OEC_LESS_TAX,
PO.APPROVED_AT AS PO_APPROVED_DATE,
POL.NOTE,
V.RULE_ID,
V.RULE_YEAR,
R.RULE,
R.REIMBURSEMENT_RATE,
CASE WHEN POL.FINANCE_STATUS  IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms')  THEN 0.00
WHEN (V.RULE_ID  = 26) AND (POL.FINANCE_STATUS NOT IN ('Dealership Floor Plan','Dealer Floor Plan','Demo Unit','Dealer - Net Terms') OR POL.FINANCE_STATUS IS NULL) THEN IFNULL(MS.REBATE_AMOUNT,0)
ELSE 0.00 END AS REIMBURSEMENT_AMOUNT
FROM ES_WAREHOUSE.PUBLIC.COMPANY_PURCHASE_ORDER_LINE_ITEMS AS POL
