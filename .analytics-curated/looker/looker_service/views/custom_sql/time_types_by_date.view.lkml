)
,work_order_type as (
select wo.work_order_id
, wo.description
  , wo.work_order_type_id
, branch_id
, wo.asset_id
, c.company_id
,case when vpp.PAYOUT_PROGRAM_ID in (8,12) then 'Paid Maintenance'
when vpp.asset_id is not null then 'Contractor'
when es.company_id is not null then 'ES'
else 'Customer'
end asset_ownership
, wo.billing_type_id
, bt.name billing_type
, date_billed
, date_completed
, wo.invoice_number
, wo.invoice_id
, total_hours
  , case when coalesce(i.company_id,i2.company_id)=1854 then 'Internal Service'
  when c.company_id=coalesce(i.company_id,i2.company_id) and asset_ownership='Customer' then 'Customer Repair' --repair
  when c.company_id=coalesce(i.company_id,i2.company_id) then 'OWN Repair'
  when coalesce(i.company_id,i2.company_id) is null and cd.work_order_id is not null then 'Unbilled Customer Damage'
  when coalesce(i.company_id,i2.company_id) is null and (wt.work_order_id is not null or wo.billing_type_id=1) and wf.asset_id is not null then 'Unbilled Warranty' --should i add on warranty eligilibity to split this out further, warranty eligible vs internal repair
  when coalesce(i.company_id,i2.company_id) is null and woo.originator_type_id=3 then 'Preventative Maintenance' --some have invoices in a different format
when coalesce(i.company_id,i2.company_id) is null and (wo.WORK_ORDER_TYPE_ID=2 or at.work_order_id is not null) then 'Inspection'
      when coalesce(i.company_id,i2.company_id) is null and tel.work_order_id is not null then 'Telematics'
      when coalesce(i.company_id,i2.company_id) is null and (mr.WORK_ORDER_ID is not null or wo.description ilike '%make ready%') then 'PDI/Make Ready'
      when coalesce(i.company_id,i2.company_id) is null and sc.work_order_id is not null then 'Field Service Call'
when coalesce(i.company_id,i2.company_id) is null then 'Internal Service' --this is currently 25% need to split further somehow
  when c.company_id!=coalesce(i.company_id,i2.company_id) and (wo.billing_type_id=1 or ic.supply_vendor or wt.work_order_id is not null) then 'Billed to OEM' --warranty
     when c.company_id!=coalesce(i.company_id,i2.company_id) then 'Billed to Customer' --customer damage
       else 'Work Order - Other' end work_order_type
from "ES_WAREHOUSE"."WORK_ORDERS"."WORK_ORDERS" wo
join "ES_WAREHOUSE"."SCD"."SCD_ASSET_COMPANY" c
  on wo.asset_id=c.asset_id
  and wo.date_completed between c.date_start and c.date_end
  join "ES_WAREHOUSE"."WORK_ORDERS"."BILLING_TYPES" bt
  on wo.billing_type_id=bt.billing_type_id
    join es_warehouse.work_orders.WORK_ORDER_ORIGINATORS woo
    on wo.WORK_ORDER_ID=woo.WORK_ORDER_ID
left join analytics.public.es_companies es
  on c.company_id=es.company_id
  left join ES_WAREHOUSE.PUBLIC.V_PAYOUT_PROGRAMS VPP
on wo.asset_id=vpp.asset_id
and wo.date_completed between VPP.START_DATE and COALESCE(VPP.END_DATE, '2099-12-31')
join hours h
on wo.work_order_id =h.work_order_id
  left join "ES_WAREHOUSE"."PUBLIC"."INVOICES" i
  on wo.invoice_id =i.invoice_id
  left join "ES_WAREHOUSE"."PUBLIC"."INVOICES" i2
  on wo.invoice_number=i2.invoice_no
    left join ES_WAREHOUSE.PUBLIC.COMPANIES ic
    on coalesce(i.COMPANY_ID,i2.COMPANY_ID)=ic.company_id
    left join warranty_final wf
    on wo.asset_id=wf.asset_id
    and wo.date_completed between wf.DELIVERY_DATE and wf.Warranty_End_Date
  LEFT JOIN (SELECT DISTINCT work_order_id -- this is customer damage
                            FROM ES_WAREHOUSE.WORK_ORDERS.WORK_ORDER_COMPANY_TAGS
                            WHERE COMPANY_TAG_ID IN (23)) cd
                           ON wo.WORK_ORDER_ID = cd.WORK_ORDER_ID
      LEFT JOIN (SELECT DISTINCT work_order_id -- this is PDI/Make Ready
                            FROM ES_WAREHOUSE.WORK_ORDERS.WORK_ORDER_COMPANY_TAGS
                            WHERE COMPANY_TAG_ID IN (28,40)) mr
                           ON wo.WORK_ORDER_ID = mr.WORK_ORDER_ID
    LEFT JOIN (SELECT DISTINCT work_order_id -- this is equipment transfer inspections
                            FROM ES_WAREHOUSE.WORK_ORDERS.WORK_ORDER_COMPANY_TAGS
                            WHERE COMPANY_TAG_ID =980) at
                           ON wo.WORK_ORDER_ID = at.WORK_ORDER_ID
     LEFT JOIN (SELECT DISTINCT work_order_id -- this is service calls
                            FROM ES_WAREHOUSE.WORK_ORDERS.WORK_ORDER_COMPANY_TAGS
                            WHERE COMPANY_TAG_ID IN (12540,49,57)) sc
                           ON wo.WORK_ORDER_ID = sc.WORK_ORDER_ID
      LEFT JOIN (SELECT DISTINCT work_order_id -- this is telematics
                            FROM ES_WAREHOUSE.WORK_ORDERS.WORK_ORDER_COMPANY_TAGS
                            WHERE COMPANY_TAG_ID IN (41,7624,5878,5017,486,400,401,2122,6436,402,403,1143,2664,716,717,9516)) tel
                           ON wo.WORK_ORDER_ID = tel.WORK_ORDER_ID
  LEFT JOIN (SELECT DISTINCT work_order_id -- this is warranty tags
                            FROM ES_WAREHOUSE.WORK_ORDERS.WORK_ORDER_COMPANY_TAGS
                            WHERE COMPANY_TAG_ID IN (11373,11140,10598,10089,
                                                     9582,9445,9444,9443,9442,
                                                     9441,9408,8936,7792,6800,
                                                     5710,5285,5183,5182,3707,55,21)) wt
                           ON wo.WORK_ORDER_ID = wt.WORK_ORDER_ID
                           where wo.asset_id is not null --there are hours on wos for other tasks

    )

 SELECT
      t.branch_id,
      date(t.start_date) as start_date,
      sum(zeroifnull(T.REGULAR_HOURS) + zeroifnull(T.OVERTIME_HOURS)) TOTAL_HOURS,
      case when work_order_type = 'Telematics' or j.name like '%Tele%' or c.name= 'Telematics Installation' then 'Telematics'
          when work_order_type ='Inspection' or j.name like '%Inspection%' then 'Inspections'
          when work_order_type is not null then work_order_type
          when t.WORK_ORDER_ID is not null then 'Work Order No Asset'
          when c.name ='Maintenance' or j.name like any ('Maintenance', 'Hydraulic','Brake','Transmission','%Repair%','%Fuel%','Service Bulletin','%Electric%','Engine','Axle%','HVAC','PDI%','Boom%') then 'Maintenance - No WO ID'
          when j.name like any('%Clean%', '%upkeep%','%Washing%') or c.name like '%Cleaning%' then 'Cleaning'
          when j.name like '%Train%' then 'Training'
          when c.name like 'Delivery%' or j.name like '%P/U%' or j.name like '%Dispatch%' then 'Delivery and Pickup'
          when j.name is not null then j.name
          when c.name is not null then c.name
          else 'Unassigned' end job_code
  from "ES_WAREHOUSE"."TIME_TRACKING"."TIME_ENTRIES" t
  left join "ES_WAREHOUSE"."TIME_TRACKING"."TIME_ENTRY_WORK_CODE_XREF" w
    on t.time_entry_id =w.time_entry_id
  left join "ES_WAREHOUSE"."TIME_TRACKING"."WORK_CODES" c
    on w.work_code_id = c.work_code_id
  left join "ES_WAREHOUSE"."PUBLIC"."JOBS" j
    on t.job_id=j.job_id
      left join work_order_type wot
      on t.WORK_ORDER_ID=wot.work_order_id
  join "ES_WAREHOUSE"."PUBLIC"."USERS" u
    on t.user_id=u.user_id
  INNER JOIN ANALYTICS.PAYROLL.COMPANY_DIRECTORY AS CD
    ON U.EMPLOYEE_ID::VARCHAR = CD.EMPLOYEE_ID::VARCHAR
where t.approval_status ='Approved'
and year(t.START_DATE)=2024
AND t.EVENT_TYPE_ID = 1
   and t.ARCHIVED_DATE is null
 and t.NEEDS_REVISION = false
 and u.company_id=1854
AND CD.EMPLOYEE_TITLE ILIKE ANY ('%technician%', '%mechanic%')
and CD.EMPLOYEE_TITLE NOT ILIKE '%yard technician%'-- Mark W says don't include yard techs
group by t.branch_id,
         job_code,
         start_date ;;
  }

  dimension: branch_id {
    type: number
    sql: ${TABLE}."BRANCH_ID" ;;
  }

  dimension_group: start_date_group {
    type: time
    timeframes: [date, week, month, year]
    sql: ${TABLE}."START_DATE" ;;
  }

  dimension: total_hours {
    type: number
    sql: ${TABLE}."TOTAL_HOURS" ;;
  }

  dimension: job_code {
    type: string
    sql: ${TABLE}."JOB_CODE" ;;
  }

  measure: unassinged_hours {
    type: sum
    sql: ${total_hours} ;;
    filters: [job_code: "Unassigned"]
  }

  measure: assinged_hours {
    type: sum
    sql: ${total_hours} ;;
    filters: [job_code: "-Unassigned"]
  }

  measure: sum_total_hours {
    type: sum
    sql: ${total_hours} ;;
  }
}
