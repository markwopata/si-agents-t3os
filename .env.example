# Copy this file to `.env.local` for local development.
# `.env` and `.env.local` are gitignored and should never be committed with real secrets.

# App runtime
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
WEB_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://si_management:si_management@localhost:54329/si_management

# Local-only auth behavior
# Do not enable either of these in hosted environments.
DEV_AUTH_BYPASS=true
T3OS_TRUST_HEADER_AUTH=false
T3OS_EXECUTIVE_EMAILS=

# Canonical JWT settings used by the API in deployed environments.
# For compatibility, AUTH0_ISSUER_BASE_URL and AUTH0_AUDIENCE are also accepted,
# but new setup should use the T3OS_JWT_* names.
T3OS_JWT_ISSUER=https://staging-auth.t3os.ai/
T3OS_JWT_AUDIENCE=https://staging-api.equipmentshare.com/es-erp-api
T3OS_JWKS_URI=
T3OS_GRAPHQL_URL=https://staging-api.equipmentshare.com/es-erp-api/graphql

# Used to encrypt stored Slack/Google tokens and sign OAuth state.
# Generate a long random value for any shared or hosted environment.
TOKEN_ENCRYPTION_SECRET=local-dev-encryption-secret

# Frontend
VITE_API_BASE_URL=http://localhost:3001
VITE_T3OS_WIDGETS_URL=https://staging-widgets.t3os.ai

# Optional integrations
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3001/integrations/slack/callback
SLACK_USER_SCOPES=channels:history,groups:history,channels:read,groups:read,users:read

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/integrations/google/callback
GOOGLE_AUTH_MODE=auto
GOOGLE_SCOPES=openid,email,profile,https://www.googleapis.com/auth/drive.readonly,https://www.googleapis.com/auth/spreadsheets.readonly

# Optional service/AI settings
OPENAI_API_KEY=
SI_AGENT_SERVICE_TOKEN=
FROSTY_BASE_URL=http://localhost:8888
FROSTY_SQL_WAREHOUSE=AD_HOC_WH
