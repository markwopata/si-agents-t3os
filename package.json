{
  "name": "si-management-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @si/api",
    "dev:web": "npm run dev -w @si/web",
    "dev:agent": "npm run dev -w @si/agent-runner",
    "build": "npm run build --workspaces --if-present",
    "build:analytics-corpus": "npm run build:analytics-corpus -w @si/api",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w @si/api",
    "import:workbook": "npm run import:workbook -w @si/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
